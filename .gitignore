# =============================================================================
# Visual Copywriter - .gitignore
# Stack: Next.js 14 / TypeScript / Tailwind CSS / macOS
# =============================================================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# --- Next.js Build Output ---
.next/
out/
build/

# --- Environment Variables (SECURITY CRITICAL) ---
# Never commit secrets. Use .env.example to document required keys.
.env
.env.*
!.env.example

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Testing / Coverage ---
coverage/
.nyc_output/

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# --- macOS System Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# --- Editors & IDEs ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# --- Vercel / Deployment ---
.vercel/

# --- Certificates ---
*.pem

# --- Optional: if you use Docker locally ---
# docker-compose.override.yml

# --- Project-specific: AI Agent Rules (keep in repo for team context) ---
# .agents/ is intentionally NOT ignored — it stores shared dev conventions.
