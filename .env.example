# Visual Copywriter - 环境变量模板
# 复制此文件为 .env.local 并填入真实值，切勿将含密钥的文件提交到 Git。
#
# Copy this file to .env.local and fill in real values.
# NEVER commit files containing actual secrets.

# Kimi API 代理地址
KIMI_API_URL=

# Kimi 代理鉴权密钥
VITE_KIMI_PROXY_URL=
VITE_KIMI_PROXY_SECRET=

# 通义千问 Qwen API Key (https://dashscope.console.aliyun.com/)
QWEN_API_KEY=

# Gemini 代理鉴权 (Cloudflare Worker)
GEMINI_PROXY_URL=https://gemini.wdqs.cn
GEMINI_PROXY_SECRET=
